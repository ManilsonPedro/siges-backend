# =============================================================
# AMBIENTE DE DESENVOLVIMENTO — Financ-BI Jennos
# Copie para .env.dev e preencha com os seus valores.
# Este ficheiro NÃO é lido em produção (Render usa env vars do dashboard).
# =============================================================

# --- Base de Dados (Neon branch "dev") ---
# Crie um branch chamado "dev" no Neon Console:
#   https://console.neon.tech → Projecto → Branches → Create branch
# Copie a connection string com sslmode=require e cole aqui:
DB_URL=postgresql+psycopg://USER:PASS@ep-XXX-dev.eu-west-2.aws.neon.tech/neondb?sslmode=require
DB_ECHO=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=0
DB_POOL_PRE_PING=true

# --- Autenticação ---
# Em DEV pode usar qualquer secret. Em PROD nunca usar este!
JWT_SECRET_KEY=dev-secret-local-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- App ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# --- CORS ---
# Frontend local Next.js corre em :3000 por defeito
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# --- Storage (uploads ficam em ./uploads localmente) ---
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# --- Redis (opcional em dev — não usado pelo código actual) ---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
