# =============================================================
# Variáveis de ambiente para produção (Render.com)
# Copiar para o dashboard do Render em Environment > Add Env Var
# NUNCA fazer commit deste ficheiro com valores reais
# =============================================================

# Base de dados (PostgreSQL — Neon.tech)
DB_URL=postgresql+psycopg://USER:PASSWORD@HOST/DATABASE?sslmode=require

# JWT — Usar uma chave aleatória forte (mínimo 32 caracteres)
JWT_SECRET_KEY=gerar-chave-aleatoria-aqui-min-32-chars

# Ambiente
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# CORS — URL do frontend no Vercel (sem barra final)
CORS_ORIGINS=https://financ-bi.vercel.app,http://localhost:3000

# Storage: usar "b2" em produção para Backblaze B2
STORAGE_TYPE=b2

# Backblaze B2 — criar Application Key em backblaze.com > App Keys
B2_KEY_ID=SEU_KEY_ID_AQUI
B2_APP_KEY=SEU_APPLICATION_KEY_AQUI
B2_BUCKET=financ-bi-jennos-aquasan
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# Tokens JWT (em minutos / dias)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
